@model carShop.Models.Car
@using System.Globalization

@{
    ViewBag.Title = "Details";
}

<h2>Car Details</h2>

<div>
    <h4>Car Information</h4>
    <hr />

    <dl class="dl-horizontal">

        <!-- IMAGE
    <dt>Image</dt>
    <dd>
        @if (!string.IsNullOrEmpty(Model.ImagePath))
        {
            <img src="~/Images/@Model.ImagePath"
                 width="250"
                 height="160"
                 class="img-thumbnail" />
        }
        else
        {
            <span>No Image Available</span>
        }
    </dd>-->
        <!-- CATEGORY -->
        <dt>Category</dt>
        <dd>
            @(Model.Category != null ? Model.Category.Name : "No Category")
        </dd>

        <!-- NAME -->
        <dt>
            @Html.DisplayNameFor(model => model.Name)
        </dt>
        <dd>
            @Html.DisplayFor(model => model.Name)
        </dd>

        <!-- DESCRIPTION -->
        <dt>
            @Html.DisplayNameFor(model => model.Description)
        </dt>
        <dd>
            @Html.DisplayFor(model => model.Description)
        </dd>

        <!-- PRICE -->
        <dt>
            @Html.DisplayNameFor(model => model.Price)
        </dt>
        <dd>
            @String.Format(new System.Globalization.CultureInfo("en-ZA"), "{0:C}", Model.Price)
        </dd>

        @if(Model.CarImageMappings!= null && Model.CarImageMappings.Any())
        {
          <dt></dt>
          <dd>
              <img src="@(Url.Content(Constants.CarImagePath) + Model.CarImageMappings.OrderBy(cim =>cim.ImageNumber).ElementAt(0).CarImage.FileName)"
                   style=padding:5px>
          </dd>
          <dt></dt>
          <dd>
              @foreach (var item in Model.CarImageMappings.OrderBy(cim =>
              cim.ImageNumber))
              {
                  <a href="@(Url.Content(Constants.CarImagePath) + item.CarImage.FileName)">
                      <img src="@(Url.Content(Constants.CarThumbnailPath) + item.CarImage.FileName)" style=padding:5px>
                  </a>
              }
          </dd>
        }

    </dl>
</div>

<p>
    @Html.ActionLink("Edit", "Edit", new { id = Model.ID },
        new { @class = "btn btn-primary" })

    @Html.ActionLink("Back to List", "Index", null,
        new { @class = "btn btn-default" })
</p>