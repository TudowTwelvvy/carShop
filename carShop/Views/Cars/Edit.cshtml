@model carShop.ViewModels.CarViewModel

@{
    ViewBag.Title = "Edit";
}

<h2>Edit Car</h2>

@using (Html.BeginForm(null, null, FormMethod.Post, new { enctype = "multipart/form-data" }))
{
    @Html.AntiForgeryToken()

<div class="form-horizontal">
    <h4>Car</h4>
    <hr />
    @Html.ValidationSummary(true, "", new { @class = "text-danger" })
    @Html.HiddenFor(model => model.ID)
    @Html.Partial("_CarEditCreatePartial")




    <!-- IMAGE UPLOAD -->
    @for (int i = 0; i < Model.ImageLists.Count; i++)
    {
        <div class="form-group">
            <label class="control-label col-md-2">Car Image @(i + 1):</label>
            <div class="col-md-10">
                @Html.DropDownListFor(vm => vm.CarImages, Model.ImageLists[i], "Choose Image",
                htmlAttributes: new { @class = "form-control" })
                @Html.ValidationMessageFor(model => model.ImageLists, "", new { @class = "text-danger" })
            </div>
        </div>
    }

    <!-- SUBMIT BUTTON -->
    <div class="form-group">
        <div class="col-md-offset-2 col-md-10">
            <input type="submit" value="Save" class="btn btn-primary" />
        </div>
    </div>
</div>
}

<div>
    @Html.ActionLink("Back to List", "Index", null, new { @class = "btn btn-default" })
</div>

@section Scripts {
    @Scripts.Render("~/bundles/jqueryval")
}